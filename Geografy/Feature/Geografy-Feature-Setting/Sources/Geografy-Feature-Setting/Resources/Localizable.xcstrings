          }
        }
      }
    },
    "All territorial dispute settings will be reset to their internationally recognized defaults." : {
      "localizations" : {
        "ka" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ტერიტორიული დავების ყველა პარამეტრი საერთაშორისოდ აღიარებულ ნაგულისხმევ მნიშვნელობებზე დაბრუნდება."
          }
        }
      }
    },
    "All your progress, XP, and achievements will be permanently deleted." : {
      "localizations" : {
        "ka" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "თქვენი მთელი პროგრესი, XP და მიღწევები სამუდამოდ წაიშლება."
